<?xml version="1.0" encoding="utf-8"?>
<!-- This screen lets the user record a new expense by filling in various details about their spending -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    tools:context=".ForthActivity">

    <!-- The top bar shows the screen name and a button to log out of the app -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        android:background="#0D47A1"
        android:gravity="center_vertical"
        android:padding="10dp">

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="@string/title_add_expense"
            android:textColor="@android:color/white"
            android:textSize="25sp"
            android:textStyle="bold"/>

        <ImageView
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:src="@android:drawable/ic_lock_power_off"
            app:tint="@color/white"
            android:onClick="login_page"
            android:contentDescription="Logout" />
    </LinearLayout>

    <!-- This middle section scrolls so the user can easily reach all the entry boxes -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- A place to enter the amount of money spent -->
            <TextView
                android:text="@string/label_amount"
                android:textColor="@android:color/black"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <EditText
                android:id="@+id/etAmount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#E5E4E2"
                android:textColor="@android:color/black"
                android:inputType="numberDecimal"
                android:padding="12dp"
                android:layout_marginBottom="16dp"
                android:autofillHints="none" />

            <!-- A place to write a short description of the expense -->
            <TextView
                android:text="@string/label_description"
                android:textColor="@android:color/black"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <EditText
                android:id="@+id/etDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#E5E4E2"
                android:textColor="@android:color/black"
                android:padding="12dp"
                android:layout_marginBottom="16dp"
                android:autofillHints="none" />

            <!-- A dropdown menu to select the category of the expense -->
            <TextView
                android:text="@string/label_category"
                android:textColor="@android:color/black"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <Spinner
                android:id="@+id/spCategory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#E5E4E2"
                android:layout_marginBottom="8dp"/>

            <!-- An extra box that appears if the user wants to type in their own custom category -->
            <EditText
                android:id="@+id/etCustomCategory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#E5E4E2"
                android:hint="Enter Custom Category"
                android:textColor="@android:color/black"
                android:padding="12dp"
                android:visibility="gone"
                android:layout_marginBottom="16dp"
                android:autofillHints="none" />

            <!-- A box that lets the user pick the date from a calendar -->
            <TextView
                android:text="@string/label_date"
                android:textColor="@android:color/black"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <EditText
                android:id="@+id/etDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#E5E4E2"
                android:textColor="@android:color/black"
                android:padding="12dp"
                android:focusable="false"
                android:clickable="true"
                android:hint="@string/hint_select_date"
                android:layout_marginBottom="16dp"
                android:autofillHints="none" />

            <!-- Two boxes side-by-side for picking when the spending started and ended -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingEnd="8dp"
                    android:paddingStart="0dp">
                    <TextView
                        android:text="@string/label_start_time"
                        android:textColor="@android:color/black"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <EditText
                        android:id="@+id/etStartTime"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#E5E4E2"
                        android:textColor="@android:color/black"
                        android:padding="12dp"
                        android:focusable="false"
                        android:clickable="true"
                        android:hint="@string/hint_time"
                        android:autofillHints="none" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="8dp"
                    android:paddingEnd="0dp">
                    <TextView
                        android:text="@string/label_end_time"
                        android:textColor="@android:color/black"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <EditText
                        android:id="@+id/etEndTime"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#E5E4E2"
                        android:textColor="@android:color/black"
                        android:padding="12dp"
                        android:focusable="false"
                        android:clickable="true"
                        android:hint="@string/hint_time"
                        android:autofillHints="none" />
                </LinearLayout>
            </LinearLayout>

            <!-- A button to select and upload a picture of the receipt -->
            <TextView
                android:text="@string/label_upload_receipt"
                android:textColor="@android:color/black"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <Button
                android:id="@+id/btnUpload"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_choose_image"
                android:backgroundTint="#1565C0"
                android:textColor="@android:color/white"
                android:layout_marginBottom="10dp"/>

            <!-- An image area to show a preview of the uploaded receipt -->
            <ImageView
                android:id="@+id/imgReceipt"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:scaleType="centerInside"
                android:background="#1B263B"
                android:src="@android:drawable/ic_menu_gallery"
                android:layout_marginBottom="20dp"
                android:contentDescription="Receipt preview" />

            <!-- The main button to save all the entered expense information -->
            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_save_expense"
                android:textColor="@android:color/white"
                android:backgroundTint="#00C853"/>
        </LinearLayout>
    </ScrollView>

    <!-- The navigation bar at the bottom for moving between different screens -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0D47A1"
        app:menu="@menu/bottom_menu"
        app:labelVisibilityMode="labeled"
        app:itemIconTint="@color/white"
        app:itemTextColor="@color/white"/>
</LinearLayout>
