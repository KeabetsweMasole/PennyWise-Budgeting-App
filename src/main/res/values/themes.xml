<!-- This file sets the overall look and feel of the app, like its primary colors and style -->
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- This section defines the main theme for the entire application -->
    <style name="Theme.Navigation" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- The main colors used for the app's branding -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary colors used for accents and other highlights -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- The color of the status bar at the very top of the phone screen -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
    </style>
</resources>